{
  "name": "barber-delivery-app",
  "version": "1.0.0",
  "description": "Mobile barber service delivery platform - Book barbers to come to your location",
  "private": true,
  "workspaces": [
    "frontend",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "cd services/api && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:api && npm run build:frontend",
    "build:api": "cd services/api && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
